# ВЕЧЕ — пример конфигурации.
# Скопируйте этот файл в .env и заполните нужные строки:  cp .env.example .env
# Всё опционально: без .env ВЕЧЕ просто запустится на порту 4040.
# Значения из реального окружения (systemd/Docker) имеют приоритет над .env.

# ── Сеть ──
# Порт, на котором слушает сервер.
PORT=4040

# ── Администраторы ──
# По умолчанию первый зарегистрировавшийся человек автоматически становится
# администратором. Можно жёстко закрепить ников через запятую (тогда авто-назначение
# первого пользователя отключается):
# ADMINS=ivan,maria

# ── Звонки (WebRTC) ──
# Для звонков между людьми за разными NAT нужен TURN-сервер (например, coturn).
# Без него звонки работают только когда прямое P2P-соединение возможно.
# TURN_HOST=turn.example.org
# TURN_SECRET=длинная-случайная-строка-совпадающая-с-настройкой-coturn

# ── ИИ-ассистент «Алиса» (опционально, YandexGPT + SpeechKit) ──
# Без ключей ассистент просто вежливо сообщит, что не настроен.
# YANDEX_API_KEY=ваш-api-ключ-яндекс-облака
# YANDEX_FOLDER_ID=идентификатор-каталога
# YANDEX_MODEL=yandexgpt-lite
